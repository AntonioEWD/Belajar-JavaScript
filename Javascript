            border-radius: 5px;
        }

        button:hover {
            background-color: navy;
        }

        .form-group {
            margin-bottom: 15px;
            background: #fff;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0 0 3px rgba(0, 0, 0, 0.1);
        }

        label {
            font-weight: bold;
            display: inline-block;
            margin-bottom: 5px;
        }

        .error-msg {
            color: red;
            font-size: 0.9em;
            margin-top: 5px;
            display: none;
            margin-top: 5px;
